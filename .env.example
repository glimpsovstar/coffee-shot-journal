# Copy to .env.local and restart the dev server. Never commit .env.local.
#
# Local dev only (optional): browser demo label scan. Do NOT set on Vercel.
# VITE_OPENAI_API_KEY=sk-your-key-here

# Vercel Production / Preview: server label scan (set in dashboard, not in client env).
# OPENAI_API_KEY=sk-your-key-here

# P3 — Supabase cloud journal (optional for local dev; required on Vercel for cloud mode)
# Use VITE_* locally, or NEXT_PUBLIC_* if mirroring Vercel Supabase integration names.
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
